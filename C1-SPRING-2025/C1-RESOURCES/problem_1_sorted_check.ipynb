   "source": [
    "# Problem 1\n",
    "Write a function that checks whether a given list of numbers is sorted in either ascending or descending order."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sample input list\n",
    "number = [2, 3, 4, 5]\n",
    "\n",
    "# Define the function\n",
    "def problem_1(nums):\n",
    "    is_ascending = True\n",
    "    is_descending = True\n",
    "\n",
    "    # Check for ascending or descending order\n",
    "    for i in range(len(nums) - 1):\n",
    "        if nums[i] > nums[i + 1]:\n",
    "            is_descending = False\n",
    "        if nums[i] < nums[i + 1]:\n",
    "            is_ascending = False\n",
    "\n",
    "    # Return True if the list is either ascending or descending\n",
    "    return is_ascending or is_descending\n",
    "\n",
    "# Test the function\n",
    "print(problem_1(number))"
   ]
  }
 ],
